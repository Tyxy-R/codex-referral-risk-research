# Keycloak local research stack
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_HTTP_PORT=8080

# Public URL used by browsers and ChatGPT SSO.
# For real ChatGPT SSO this must be HTTPS and publicly reachable.
KEYCLOAK_HOSTNAME=http://localhost:8080

# Realm and client labels used by the setup notes.
KEYCLOAK_REALM=chatgpt-research
CHATGPT_SAML_CLIENT_NAME=ChatGPT SSO

# Fill these from the ChatGPT SSO wizard. Do not guess them.
CHATGPT_SAML_ENTITY_ID=
CHATGPT_SAML_ACS_URL=
